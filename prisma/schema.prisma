// Schéma de l'étude craving/activité physique.
// RGPD : aucune donnée nominative — les participants sont identifiés par code (P01..P20) uniquement.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Groupe {
  EXPERIMENTAL
  CONTROLE
}

enum SousGroupe {
  A
  B
}

enum Sexe {
  HOMME
  FEMME
  AUTRE
}

enum Modalite {
  CARDIO
  MUSCULATION
}

enum Ordre {
  PREMIERE
  DEUXIEME
}

enum Temps {
  T0
  T1
  T2
}

model Participant {
  code       String     @id
  groupe     Groupe
  age        Int
  sexe       Sexe
  sousGroupe SousGroupe
  createdAt  DateTime   @default(now())

  mesuresSeance MesureSeance[]
  carnetsJour   CarnetJour[]
  mesuresSuivi  MesureSuivi[]
}

model MesureSeance {
  id              Int      @id @default(autoincrement())
  participant     Participant @relation(fields: [participantCode], references: [code], onDelete: Cascade)
  participantCode String
  semaine         Int
  numeroSeance    Int
  modalite        Modalite
  ordre           Ordre
  heureDebut      DateTime?

  cravingAvant Int?
  cravingApres Int?
  deltaCraving Int?

  rpeReel                   Int?
  heuresDepuisDerniereConso Float?
  remarque                  String?

  createdAt DateTime @default(now())

  @@unique([participantCode, semaine, numeroSeance])
}

model CarnetJour {
  id              Int      @id @default(autoincrement())
  participant     Participant @relation(fields: [participantCode], references: [code], onDelete: Cascade)
  participantCode String
  date            DateTime

  cigarettes           Int?
  /// % du goût (puff Adalya 20K) utilisé dans la journée (0-100)
  puffPourcentage      Int?
  snusSachets          Int?
  cravingMoyenJour     Int?
  evenementParticulier String?

  createdAt DateTime @default(now())

  @@unique([participantCode, date])
}

model MesureSuivi {
  id              Int      @id @default(autoincrement())
  participant     Participant @relation(fields: [participantCode], references: [code], onDelete: Cascade)
  participantCode String
  temps           Temps

  scoreFagerstrom     Int?
  consoMoyenneSemaine Float?
  test6min            Float?
  poids               Float?
  imc                 Float?
  tourTaille          Float?

  /// Envie d'arrêter la nicotine (0 = aucune envie, 10 = envie maximale)
  envieArreter Int?
  /// "Si vous décidiez de réduire votre consommation, à quel point vous sentez-vous
  /// capable d'y arriver ?" (0 = pas capable du tout, 10 = tout à fait capable)
  capaciteReduireConso Int?

  /// QSU-Brief (Cox, Tiffany & Christen, 2001), adapté à la nicotine — 10 items, échelle 1 (pas du tout d'accord) à 7 (tout à fait d'accord)
  qsu1  Int?
  qsu2  Int?
  qsu3  Int?
  qsu4  Int?
  qsu5  Int?
  qsu6  Int?
  qsu7  Int?
  qsu8  Int?
  qsu9  Int?
  qsu10 Int?

  /// Score total QSU-Brief, calculé automatiquement (moyenne des 10 items renseignés)
  scoreCravingTrait Float?
  /// Facteur 1 (désir/intention de consommer) — moyenne des items 1,3,6,7,9
  qsuFacteur1 Float?
  /// Facteur 2 (soulagement du manque) — moyenne des items 2,4,5,8,10
  qsuFacteur2 Float?

  createdAt DateTime @default(now())

  @@unique([participantCode, temps])
}
