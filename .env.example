# Base SQLite — en production, pointe vers un chemin sur un disque persistant
# (ex : Railway volume monté sur /data) pour ne pas perdre les données à chaque déploiement.
DATABASE_URL="file:./dev.db"

# Mot de passe unique pour l'accès admin (back-office, dashboard).
# Choisis un vrai mot de passe fort avant la mise en ligne.
ADMIN_PASSWORD="change-moi"

# Secret utilisé pour signer le cookie de session admin.
# Génère une longue chaîne aléatoire avant la mise en ligne (ex : openssl rand -hex 32).
AUTH_SECRET="change-moi-aussi-une-longue-chaine-aleatoire"
